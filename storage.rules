rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// Vinora — Firebase Storage Security Rules (fotky etiket)
// ═══════════════════════════════════════════════════════════════════════════
// Nasazení:  firebase deploy --only storage
// ═══════════════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.email == 'kamil.jurik@easyportal365.com'; }

    // Cesta:  vina/{userId}/{vinoId}_{timestamp}.jpg
    match /vina/{userId}/{filename} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 4 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
